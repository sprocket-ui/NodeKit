{
  "name": "@sprocketui-react/popover",
  "version": "1.1.2",
  "description": "Sprocket's standalone React popover component.",
  "type": "module",
  "license": "MIT",
  "author": "Corinvo OSS Team",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build-disabled": "tsup",
    "test": "vitest",
    "dev": "tsup --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sprocket-ui/NodeKit.git"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.0",
    "@necto-react/components": "1.4.25",
    "@necto-react/helpers": "2.6.16",
    "@necto-react/hooks": "2.16.2",
    "@necto-react/state": "0.2.1",
    "@necto/mergers": "1.5.1",
    "@necto/strings": "1.7.0",
    "@sprocketui-types/popover": "workspace:*"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0-rc.1",
    "react-dom": "^16.8.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0-rc.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shared": "workspace:*",
    "tsup": "^8.4.0",
    "vitest": "^3.2.4"
  }
}
