{
  "name": "@sprocketui-react/checkbox",
  "version": "1.1.2",
  "description": "Sprocket's standalone React checkbox component.",
  "type": "module",
  "license": "MIT",
  "author": "Corinvo OSS Team",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
