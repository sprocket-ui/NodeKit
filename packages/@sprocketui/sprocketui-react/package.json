{
  "name": "@sprocketui/react",
  "version": "0.2.26",
  "type": "module",
  "license": "MIT",
  "author": "Corinvo OSS Team",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "clean-publish --without-publish --temp-dir .clean",
    "test": "vitest",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "directory": ".clean"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sprocket-ui/NodeKit.git"
  },
  "dependencies": {
    "@sprocketui-react/button": "workspace:*",
    "@sprocketui-react/input": "workspace:*",
    "@sprocketui-react/tabs": "workspace:*",
    "@sprocketui-react/tooltip": "workspace:*",
    "@sprocketui-react/label": "workspace:*"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0-rc.1",
    "react-dom": "^16.8.0 || ^17.0.0-rc.1 || ^18.0.0 || ^19.0.0-rc.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.4.0"
  }
}
